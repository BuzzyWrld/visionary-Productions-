# Visionary Productions environment variables.
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Booking. Calendly inline embed plus deep links from Inquire CTAs.
PUBLIC_CALENDLY_URL=https://calendly.com/your-handle/session

# Deposit. A hosted Stripe Payment Link. No custom checkout, no card handling here.
PUBLIC_STRIPE_DEPOSIT_URL=https://buy.stripe.com/your-deposit-link

# Newsletter. Beehiiv embed snippet or the publication embed URL.
PUBLIC_BEEHIIV_EMBED=https://embeds.beehiiv.com/your-embed-id

# Contact form. Posts to Airtable via the serverless endpoint. Server only.
# These must never be exposed to the client, so no PUBLIC_ prefix.
AIRTABLE_TOKEN=pat_xxx
AIRTABLE_BASE=app_xxx
AIRTABLE_TABLE=Inquiries
