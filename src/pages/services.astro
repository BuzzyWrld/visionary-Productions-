---
import Base from '../layouts/Base.astro';
import '../styles/content.css';

const title = 'Services & Pricing | Visionary Productions, NYC Photographer';
const description =
  'What Kai shoots and what it runs. Events, fashion and editorial, lifestyle. Vision Session, Brand Day, and Event Coverage. Deposit to lock the date.';

const services = [
  { k: 'The Night', h: 'Events', p: 'The room, the energy, the people. I shoot the night so it still feels like the night when you look back. Parties, shows, launches, the community out in full.' },
  { k: 'The Look', h: 'Fashion & Editorial', p: 'Portraits and stories with intention. Brand work, lookbooks, editorial sets. Same style every time, on purpose, so nobody walks away looking like anybody else.' },
  { k: 'The Everyday', h: 'Lifestyle', p: 'Real moments, golden hour, the everyday made to matter. Personal sessions, couples, the small things that turn out to be the whole thing.' },
];

// PRICES ARE PLACEHOLDERS. Confirm the real numbers with Kai before publishing
// (build brief section 6 + 14). Structure is correct, values are pending.
const tiers = [
  {
    k: 'The Portrait', h: 'Vision Session', price: 'From $—', unit: 'per session', feature: false,
    points: ['One to two hours, one look or location', 'Direction the whole way, you will not feel stiff', 'Curated, color graded gallery', 'Personal use license'],
  },
  {
    k: 'The Brand', h: 'Brand Day', price: 'From $—', unit: 'per day', feature: true,
    points: ['Half or full day, multiple looks', 'Built for brands, lookbooks, and editorial', 'Larger curated, graded gallery', 'Commercial use license', 'Same style, start to finish'],
  },
  {
    k: 'The Night', h: 'Event Coverage', price: 'From $—', unit: 'per event', feature: false,
    points: ['Hourly, the full room covered', 'Fast turnaround on a teaser set', 'Full graded gallery after', 'Add hours as the night runs'],
  },
];
---
<Base title={title} description={description} activeNav="services" footerHome={true}>
  <section class="page">
    <div class="page-head">
      <div class="eyebrow reveal">Services</div>
      <h1 class="reveal">What I shoot, and what it runs.</h1>
      <p class="lead reveal">Three lanes, one approach. Bring the vision, I handle the execution. Every booking locks with a deposit and gets the same care no matter the size.</p>
    </div>
    <div class="svc-grid">
      {services.map((s) => (
        <div class="svc reveal">
          <div class="k">{s.k}</div>
          <h3>{s.h}</h3>
          <p>{s.p}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="page" id="pricing" style="padding-top:0">
    <div class="page-head">
      <div class="eyebrow reveal">Pricing</div>
      <h2 class="reveal" style="font-family:var(--font-d);font-weight:600;font-size:clamp(30px,5vw,58px);line-height:1.05;letter-spacing:-.02em">Straight, no games.</h2>
      <p class="lead reveal">Pick the lane that fits. A deposit locks your date and comes off the total. The work is the same whether the room is big or small.</p>
    </div>
    <div class="tiers">
      {tiers.map((t) => (
        <div class={t.feature ? 'tier feature reveal' : 'tier reveal'}>
          <div class="k">{t.k}</div>
          <h3>{t.h}</h3>
          <div class="price">{t.price} <span>{t.unit}</span></div>
          <ul>{t.points.map((p) => <li>{p}</li>)}</ul>
          <a class="btn btn-accent" href="/contact">Start An Inquiry</a>
        </div>
      ))}
    </div>
    <div class="price-note reveal">
      Deposit to book, balance due on the day. No discounts, the rate is the rate.
      Travel outside NYC quoted per job. Final numbers confirmed on inquiry.
    </div>
  </section>

  <section class="cta-band" id="inquire">
    <div class="reveal">
      <h2>Got A Vision? Let&rsquo;s Execute It.</h2>
      <p>Book a session. Deposit to lock the date.</p>
      <a class="btn" href="/contact">Start An Inquiry</a>
    </div>
  </section>
</Base>
