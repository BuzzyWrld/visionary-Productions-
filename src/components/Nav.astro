---
import Logo from './Logo.astro';

// Minimal nav. The logo always returns home, one accented Inquire button is the
// only persistent action. Work and Services are reached from the home page and
// the footer, so no link row clutters the bar. The `active` prop is accepted for
// backward compatibility but no longer renders a link state.
interface Props {
  active?: 'work' | 'services' | 'pricing' | null;
}
---
<nav class="nav">
  <a class="brand" href="/" aria-label="Visionary Productions home">
    <Logo size={40} />
    <span><div class="wm">VISIONARY</div><div class="sub">PRODUCTIONS</div></span>
  </a>
  <div class="navlinks">
    <a class="inquire" href="/contact">Inquire</a>
  </div>
</nav>
