---
// Viewfinder crop mark brackets framing a single V. Uses currentColor so it
// flips with the theme. Size is controlled by the `size` prop.
interface Props {
  size?: number;
  class?: string;
}
const { size = 40, class: className } = Astro.props;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 40 40"
  fill="none"
  aria-hidden="true"
  class={className}
>
  <g stroke="currentColor" stroke-width="2.4" stroke-linecap="square">
    <path d="M3 11 L3 3 L11 3" />
    <path d="M29 3 L37 3 L37 11" />
    <path d="M37 29 L37 37 L29 37" />
    <path d="M11 37 L3 37 L3 29" />
  </g>
  <text
    x="20" y="26"
    text-anchor="middle"
    font-family="Fraunces, serif"
    font-weight="600"
    font-size="18"
    fill="currentColor"
  >V</text>
</svg>
